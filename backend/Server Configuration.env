# Server Configuration
PORT=5000

# Database — replace the password with YOUR postgres password from Phase 1
DB_HOST=localhost
DB_PORT=5432
DB_NAME=legal_ai_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# JWT Secret — this is used to sign login tokens
# Make this long and random. You can use any random string.
JWT_SECRET=my_super_secret_legal_ai_jwt_key_2025_change_this

# JWT Token expiry — tokens expire after 7 days
JWT_EXPIRES_IN=7d

# Anthropic API Key — paste yours here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Environment
NODE_ENV=development